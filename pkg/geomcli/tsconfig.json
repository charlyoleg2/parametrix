{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rewriteRelativeImportExtensions": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true,
		"types": ["node"],
		"strict": true,
		"outDir": "./build",
		"module": "NodeNext",
		"moduleResolution": "NodeNext"
	},
	"include": ["./src"]
}
