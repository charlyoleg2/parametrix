{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "esnext",
		"module": "esnext",
		"outDir": "./build",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"declaration": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"types": ["node"]
	},
	"include": ["./src"]
}
